# WordPress core (if repo includes WP install)
# -----------------------
wp-admin/
wp-includes/

# Ignore everything in uploads
wp-content/uploads/*

# Keep themes/plugins (optional depending on setup)
!wp-content/themes/
!wp-content/plugins/

